{
  "name": "onebite-backup-companion",
  "version": "1.0.10-beta.42",
  "description": "Windows backup and sync desktop app for One Bite Technology customers.",
  "main": "main.js",
  "author": "One Bite Technology",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/onebitetechnology/OBTools-Automated-DataBackup.git"
  },
  "scripts": {
    "start": "electron .",
    "start:web": "node server.js",
    "dist:win": "electron-builder --config electron-builder.config.js --win nsis --publish never",
    "pack": "electron-builder --config electron-builder.config.js --dir",
    "release:win": "electron-builder --config electron-builder.config.js --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^26.0.12"
  }
}
